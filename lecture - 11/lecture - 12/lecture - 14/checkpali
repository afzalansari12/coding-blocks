#include<iostream>

using namespace std;

bool ispalindrome(char str[]) {

    int n = strlen(str);
    int i =0;
    int  j = n-1;

    while(i < j){

        if(str[i] != str[j]){
            return false;
        }
        i++;
        j--;
    }
      
      
      return true;


}

int main(){

    char str[] = " racecar";
    ispalindrome(str) ? cout << "true" << endl:cout << "false" << endl;

    return 0;

}